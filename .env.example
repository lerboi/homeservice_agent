# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (set to production domain in deployed environments)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Retell AI
RETELL_API_KEY=your-retell-api-key
RETELL_SIP_TRUNK_TERMINATION_URI=your-sip-trunk-uri

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_STARTER_OVERAGE=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_GROWTH_OVERAGE=price_...
STRIPE_PRICE_SCALE=price_...
STRIPE_PRICE_SCALE_ANNUAL=price_...
STRIPE_PRICE_SCALE_OVERAGE=price_...

# Resend (transactional email)
RESEND_API_KEY=re_...

# Twilio (SMS + phone provisioning)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft/Outlook Calendar OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
OUTLOOK_WEBHOOK_SECRET=your-outlook-webhook-secret

# ElevenLabs (demo voice)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID_AI=your-voice-id

# Sentry (error monitoring)
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_TEST_SECRET=your-sentry-test-secret

# Contact form email routing
CONTACT_EMAIL_SALES=sales@getvoco.ai
CONTACT_EMAIL_SUPPORT=support@getvoco.ai
CONTACT_EMAIL_PARTNERSHIPS=partnerships@getvoco.ai
CONTACT_EMAIL_FALLBACK=hello@getvoco.ai

# Cron secret (Vercel Cron authentication)
CRON_SECRET=your-random-cron-secret

# Groq (used by retell-ws-server, not this repo directly)
GROQ_API_KEY=your-groq-key
